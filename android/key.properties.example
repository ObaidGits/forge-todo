# Android release signing configuration (TEMPLATE — safe to commit).
#
# To enable signed release builds:
#   1. Create your upload keystore ONCE (keep it and these passwords safe forever):
#        keytool -genkey -v -keystore ~/forge-upload.jks \
#          -keyalg RSA -keysize 2048 -validity 10000 -alias forge-upload
#   2. Copy this file to `android/key.properties` (that real file is gitignored)
#      and fill in your actual values below.
#   3. Build:
#        flutter build appbundle --release   # .aab for Play Store (preferred)
#        flutter build apk --release         # .apk for direct install
#
# WARNING: never commit the real key.properties or the .jks keystore. Losing the
# keystore means you can no longer update a published app unless you enrolled in
# Google Play App Signing (strongly recommended).

storePassword=<your keystore password>
keyPassword=<your key password>
keyAlias=forge-upload
storeFile=/home/obaid/forge-upload.jks
